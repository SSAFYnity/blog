---
import SiteFooter from '../components/SiteFooter.astro'
import SiteHeader from '../components/SiteHeader.astro'
import '../styles/global.css'
import { site, toAbsoluteBlogUrl } from '../data/site'

interface Props {
  title?: string
  description?: string
  canonical?: string
  image?: string
  metaType?: 'website' | 'article'
  noindex?: boolean
  analyticsEvent?: {
    name: string
    params?: Record<string, string>
  }
}

const {
  title = site.title,
  description = site.description,
  canonical = toAbsoluteBlogUrl(Astro.url.pathname),
  image = site.ogImage,
  metaType = 'website',
  noindex = false,
  analyticsEvent,
} = Astro.props

const GA_MEASUREMENT_ID = 'G-2W9HFYG765'
const isAnalyticsEnabled = import.meta.env.PROD && GA_MEASUREMENT_ID.length > 0
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="theme-color" content="#1E3A8A" />
    <meta
      name="google-site-verification"
      content="xWE3kfqYc75gEiII_BGzPNT7R_eHhDrBGHW7OlLz1-M"
    />
    <link rel="icon" type="image/x-icon" href="/blog/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/blog/logo-icon.svg" />
    <link rel="apple-touch-icon" href="/blog/logo-icon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={metaType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <title>{title}</title>
    {isAnalyticsEnabled && (
      <>
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
        ></script>
        <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = window.gtag || gtag;
          gtag('js', new Date());
          gtag('config', GA_MEASUREMENT_ID, { send_page_view: false });
        </script>
      </>
    )}
  </head>
  <body>
    <div class="page-bg" aria-hidden="true"></div>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
    {isAnalyticsEnabled && (
      <script is:inline>
        window.gtag && window.gtag('event', 'page_view', {
          page_path: window.location.pathname,
          page_title: document.title,
          page_location: window.location.href,
        });
      </script>
    )}
    {isAnalyticsEnabled && analyticsEvent && (
      <script
        is:inline
        define:vars={{
          analyticsEventName: analyticsEvent.name,
          analyticsEventPayload: {
            page_path: Astro.url.pathname,
            page_location: Astro.url.href,
            page_title: title,
            ...analyticsEvent.params,
          },
        }}
      >
        window.gtag && window.gtag('event', analyticsEventName, analyticsEventPayload);
      </script>
    )}
    {isAnalyticsEnabled && (
      <script is:inline>
        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const anchor = target.closest('a[data-analytics-event]');
          if (!(anchor instanceof HTMLAnchorElement)) return;
          if (!window.gtag) return;

          const rawPayload = anchor.dataset.analyticsPayload;
          let payload = {};

          if (rawPayload) {
            try {
              payload = JSON.parse(rawPayload);
            } catch {
              payload = {};
            }
          }

          window.gtag('event', anchor.dataset.analyticsEvent, {
            page_path: window.location.pathname,
            page_title: document.title,
            ...payload,
          });
        });
      </script>
    )}
  </body>
</html>
