---
import SiteFooter from '../components/SiteFooter.astro'
import SiteHeader from '../components/SiteHeader.astro'
import '../styles/global.css'
import { site } from '../data/site'

interface Props {
  title?: string
  description?: string
  analyticsEvent?: {
    name: string
    params?: Record<string, string>
  }
}

const {
  title = site.title,
  description = site.description,
  analyticsEvent,
} = Astro.props

const GA_MEASUREMENT_ID = 'G-2W9HFYG765'
const isAnalyticsEnabled = import.meta.env.PROD && GA_MEASUREMENT_ID.length > 0
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1E3A8A" />
    <link rel="icon" type="image/x-icon" href="/blog/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/blog/logo-icon.svg" />
    <link rel="apple-touch-icon" href="/blog/logo-icon.svg" />
    <title>{title}</title>
    {isAnalyticsEnabled && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
        ></script>
        <script is:inline>
          {`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = window.gtag || gtag;
            gtag('js', new Date());
            gtag('config', '${GA_MEASUREMENT_ID}');
          `}
        </script>
      </>
    )}
  </head>
  <body>
    <div class="page-bg" aria-hidden="true"></div>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
    {isAnalyticsEnabled && analyticsEvent && (
      <script is:inline>
        {`
          window.gtag && window.gtag('event', ${JSON.stringify(analyticsEvent.name)}, ${JSON.stringify({
            page_path: Astro.url.pathname,
            page_title: title,
            ...analyticsEvent.params,
          })});
        `}
      </script>
    )}
    {isAnalyticsEnabled && (
      <script is:inline>
        {`
          document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const anchor = target.closest('a[data-analytics-event]');
            if (!(anchor instanceof HTMLAnchorElement)) return;
            if (!window.gtag) return;

            const rawPayload = anchor.dataset.analyticsPayload;
            let payload = {};

            if (rawPayload) {
              try {
                payload = JSON.parse(rawPayload);
              } catch {
                payload = {};
              }
            }

            window.gtag('event', anchor.dataset.analyticsEvent, {
              page_path: window.location.pathname,
              page_title: document.title,
              ...payload,
            });
          });
        `}
      </script>
    )}
  </body>
</html>
