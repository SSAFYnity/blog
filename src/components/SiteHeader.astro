---
import { site } from '../data/site'

const currentPath = Astro.url.pathname
const normalizedPath = currentPath.endsWith('/') ? currentPath : `${currentPath}/`
const isHomePath = normalizedPath === '/blog/' || normalizedPath === '/'

const navItems = [
  ...site.categories.map((category) => ({
    label: category.title,
    href: `/blog/category/${category.slug}/`,
  })),
]

const isActive = (href: string) => {
  return currentPath.startsWith(href)
}
---

<header
  class:list={['site-header', { 'is-home': isHomePath }]}
  data-site-header
>
  <div class="shell header-inner">
    <a class="brand" href="/blog/" aria-label={`${site.shortName} 블로그 홈`}>
      <img class="brand-logo" src="/blog/logo-rect.png" alt="SSAFYnity" />
      <span class="brand-copy">
        <strong>{site.shortName}</strong>
        <span>Alumni Association</span>
      </span>
    </a>

    <nav class="nav" aria-label="블로그 주요 메뉴">
      {navItems.map((item) => (
        <a
          class:list={['nav-link', { 'is-active': isActive(item.href) }]}
          href={item.href}
          target={item.href.startsWith('http') ? '_blank' : undefined}
          rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      class="mobile-nav-toggle"
      type="button"
      aria-label="메뉴 열기"
      aria-controls="mobile-nav-drawer"
      aria-expanded="false"
      data-mobile-nav-toggle
    >
      <svg class="mobile-nav-toggle-open" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4.5 7.5h15M4.5 12h15M4.5 16.5h15"></path>
      </svg>
    </button>
  </div>

  <div class="mobile-nav-backdrop" data-mobile-nav-backdrop></div>
  <div
    class="mobile-nav-drawer"
    id="mobile-nav-drawer"
    aria-label="모바일 메뉴"
    data-mobile-nav-drawer
    >
    <div class="mobile-nav-shell">
      <button
        class="mobile-nav-close"
        type="button"
        aria-label="메뉴 닫기"
        data-mobile-nav-close
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m6.75 6.75 10.5 10.5M17.25 6.75 6.75 17.25"></path>
        </svg>
      </button>
      <div class="mobile-nav-group">
        <p class="mobile-nav-title">블로그</p>
        <nav class="mobile-nav-links" aria-label="모바일 블로그 메뉴">
          {navItems.map((item) => (
            <a
              class:list={['mobile-nav-link', { 'is-active': isActive(item.href) }]}
              href={item.href}
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
            >
              <span>{item.label}</span>
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]')
  const menuToggle = header?.querySelector<HTMLButtonElement>('[data-mobile-nav-toggle]')
  const menuClose = header?.querySelector<HTMLButtonElement>('[data-mobile-nav-close]')
  const menuDrawer = header?.querySelector<HTMLElement>('[data-mobile-nav-drawer]')
  const menuBackdrop = header?.querySelector<HTMLElement>('[data-mobile-nav-backdrop]')
  const menuLinks = menuDrawer?.querySelectorAll<HTMLAnchorElement>('a') ?? []

  const closeMobileMenu = () => {
    if (!header || !menuToggle || !menuDrawer || !menuBackdrop) return

    header.classList.remove('is-mobile-open')
    menuToggle.setAttribute('aria-expanded', 'false')
    document.body.classList.remove('is-mobile-nav-open')
  }

  const openMobileMenu = () => {
    if (!header || !menuToggle || !menuDrawer || !menuBackdrop) return

    header.classList.add('is-mobile-open')
    menuToggle.setAttribute('aria-expanded', 'true')
    document.body.classList.add('is-mobile-nav-open')
  }

  if (header) {
    const isHome = header.classList.contains('is-home')

    const syncScrolled = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 20 || !isHome)
    }

    syncScrolled()
    window.addEventListener('scroll', syncScrolled, { passive: true })
  }

  menuToggle?.addEventListener('click', () => {
    const isOpen = header?.classList.contains('is-mobile-open')

    if (isOpen) {
      closeMobileMenu()
      return
    }

    openMobileMenu()
  })

  menuBackdrop?.addEventListener('click', closeMobileMenu)
  menuClose?.addEventListener('click', closeMobileMenu)

  menuLinks.forEach((link) => {
    link.addEventListener('click', closeMobileMenu)
  })

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMobileMenu()
    }
  })

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) {
      closeMobileMenu()
    }
  })
</script>
