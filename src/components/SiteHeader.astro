---
import { navGroups, site, type CategorySlug } from '../data/site'

const currentPath = Astro.url.pathname
const normalizedPath = currentPath.endsWith('/') ? currentPath : `${currentPath}/`
const isHomePath = normalizedPath === '/blog/' || normalizedPath === '/'
const isHrefActive = (href: string) => normalizedPath.startsWith(href)
const isSlugActive = (slug: CategorySlug) => normalizedPath.startsWith(`/blog/category/${slug}/`)

type NavGroup = (typeof navGroups)[number]

const topLevelCategoryLinks = navGroups
  .filter((item): item is Extract<NavGroup, { type: 'link' }> => item.type === 'link')
  .map((item) => ({
    label: item.label,
    href: item.href,
    slug: item.slugs[0],
  }))

const mobileNavGroups = [
  {
    label: '콘텐츠',
    items: topLevelCategoryLinks,
  },
  ...navGroups
    .filter((item): item is Extract<NavGroup, { type: 'group' }> => item.type === 'group')
    .map((item) => ({
      label: item.label,
      items: item.items,
    })),
]
---

<header
  class:list={['site-header', { 'is-home': isHomePath }]}
  data-site-header
>
  <div class="shell header-inner">
    <a class="brand" href="/blog/" aria-label={`${site.shortName} 블로그 홈`}>
      <img class="brand-logo" src="/blog/logo-rect.png" alt="SSAFYnity" />
      <span class="brand-copy">
        <strong>{site.shortName}</strong>
        <span>Alumni Association</span>
      </span>
    </a>

    <nav class="nav" aria-label="블로그 주요 메뉴">
      {navGroups.map((item, index) =>
        item.type === 'link' ? (
          <a
            class:list={['nav-link', { 'is-active': item.slugs.some((slug) => isSlugActive(slug)) }]}
            href={item.href}
          >
            {item.label}
          </a>
        ) : (
          <div class:list={['nav-group', { 'is-active': item.items.some((child) => isSlugActive(child.slug)) }]} data-nav-group>
            <button
              class="nav-group-trigger"
              type="button"
              aria-expanded="false"
              aria-controls={`nav-group-panel-${index}`}
              data-nav-group-trigger
            >
              <span>{item.label}</span>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m6.75 9 5.25 5.25L17.25 9"></path>
              </svg>
            </button>
            <div class="nav-group-menu" id={`nav-group-panel-${index}`} data-nav-group-menu hidden>
              {item.items.map((child) => (
                <a
                  class:list={['nav-group-link', { 'is-active': isSlugActive(child.slug) }]}
                  href={child.href}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ),
      )}
    </nav>

    <button
      class="mobile-nav-toggle"
      type="button"
      aria-label="메뉴 열기"
      aria-controls="mobile-nav-drawer"
      aria-expanded="false"
      data-mobile-nav-toggle
    >
      <svg class="mobile-nav-toggle-open" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4.5 7.5h15M4.5 12h15M4.5 16.5h15"></path>
      </svg>
    </button>
  </div>

  <div class="mobile-nav-backdrop" data-mobile-nav-backdrop></div>
  <div
    class="mobile-nav-drawer"
    id="mobile-nav-drawer"
    aria-label="모바일 메뉴"
    aria-hidden="true"
    data-mobile-nav-drawer
    >
    <div class="mobile-nav-shell">
      <div class="mobile-nav-head">
        <p class="mobile-nav-heading">메뉴</p>
        <button
          class="mobile-nav-close"
          type="button"
          aria-label="메뉴 닫기"
          data-mobile-nav-close
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6.75 6.75 10.5 10.5M17.25 6.75 6.75 17.25"></path>
          </svg>
        </button>
      </div>
      <div class="mobile-nav-group">
        <nav class="mobile-nav-links" aria-label="모바일 블로그 메뉴">
          {mobileNavGroups.map((group) => (
            <div class="mobile-nav-section">
              <p class="mobile-nav-title">{group.label}</p>
              <div class="mobile-nav-group-links">
                {group.items.map((child) => (
                  <a
                    class:list={['mobile-nav-link', 'is-child', { 'is-active': isSlugActive(child.slug) }]}
                    href={child.href}
                  >
                    <span>{child.label}</span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </nav>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]')
  const menuToggle = header?.querySelector<HTMLButtonElement>('[data-mobile-nav-toggle]')
  const menuClose = header?.querySelector<HTMLButtonElement>('[data-mobile-nav-close]')
  const menuDrawer = header?.querySelector<HTMLElement>('[data-mobile-nav-drawer]')
  const menuBackdrop = header?.querySelector<HTMLElement>('[data-mobile-nav-backdrop]')
  const menuLinks = menuDrawer?.querySelectorAll<HTMLAnchorElement>('a') ?? []
  const desktopGroups = header?.querySelectorAll<HTMLElement>('[data-nav-group]') ?? []

  const openDesktopGroup = (group: HTMLElement) => {
    const trigger = group.querySelector<HTMLButtonElement>('[data-nav-group-trigger]')
    const menu = group.querySelector<HTMLElement>('[data-nav-group-menu]')
    if (!trigger || !menu) return

    closeDesktopGroups()
    group.classList.add('is-open')
    trigger.setAttribute('aria-expanded', 'true')
    menu.hidden = false
  }

  const closeDesktopGroups = () => {
    desktopGroups.forEach((group) => {
      const trigger = group.querySelector<HTMLButtonElement>('[data-nav-group-trigger]')
      const menu = group.querySelector<HTMLElement>('[data-nav-group-menu]')
      group.classList.remove('is-open')
      trigger?.setAttribute('aria-expanded', 'false')
      if (menu) {
        menu.hidden = true
      }
    })
  }

  const closeMobileMenu = () => {
    if (!header || !menuToggle || !menuDrawer || !menuBackdrop) return
    const savedScrollY = Number(document.body.dataset.scrollY || '0')

    header.classList.remove('is-mobile-open')
    menuToggle.setAttribute('aria-expanded', 'false')
    menuDrawer.setAttribute('aria-hidden', 'true')
    document.body.classList.remove('is-mobile-nav-open')
    document.body.style.top = ''
    delete document.body.dataset.scrollY
    window.scrollTo(0, savedScrollY)
  }

  const openMobileMenu = () => {
    if (!header || !menuToggle || !menuDrawer || !menuBackdrop) return
    const scrollY = window.scrollY

    header.classList.add('is-mobile-open')
    menuToggle.setAttribute('aria-expanded', 'true')
    menuDrawer.setAttribute('aria-hidden', 'false')
    document.body.dataset.scrollY = String(scrollY)
    document.body.style.top = `-${scrollY}px`
    document.body.classList.add('is-mobile-nav-open')
  }

  if (header) {
    const isHome = header.classList.contains('is-home')

    const syncScrolled = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 20 || !isHome)
    }

    syncScrolled()
    window.addEventListener('scroll', syncScrolled, { passive: true })
  }

  menuToggle?.addEventListener('click', () => {
    const isOpen = header?.classList.contains('is-mobile-open')

    if (isOpen) {
      closeMobileMenu()
      return
    }

    openMobileMenu()
  })

  menuBackdrop?.addEventListener('click', closeMobileMenu)
  menuClose?.addEventListener('click', closeMobileMenu)

  desktopGroups.forEach((group) => {
    const trigger = group.querySelector<HTMLButtonElement>('[data-nav-group-trigger]')
    const menu = group.querySelector<HTMLElement>('[data-nav-group-menu]')

    if (!trigger || !menu) return

    group.addEventListener('mouseenter', () => {
      if (window.innerWidth < 1024) return
      openDesktopGroup(group)
    })

    group.addEventListener('mouseleave', () => {
      if (window.innerWidth < 1024) return
      closeDesktopGroups()
    })
  })

  menuLinks.forEach((link) => {
    link.addEventListener('click', closeMobileMenu)
  })

  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Node) || !header) return
    if (header.contains(event.target)) return
    closeDesktopGroups()
  })

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeDesktopGroups()
      closeMobileMenu()
    }
  })

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) {
      closeMobileMenu()
    }
  })
</script>
