  {
    label: 'Start',
    title: '처음 보는 분에게',
    description: '블로그의 방향과 동문회 주요 안내를 먼저 확인할 수 있는 공식 소식입니다.',
    href: '/blog/category/notice/',
    iconClass: 'is-navy',
    iconPath: 'M14.25 18a2.25 2.25 0 0 1-4.5 0m7.5-7.5V9a5.25 5.25 0 1 0-10.5 0v1.5L5.25 13.5h13.5l-1.5-3Z',
    links: [
      { label: '공지', href: '/blog/category/notice/' },
      { label: '회비', href: '/blog/category/finance/' },
    ],
  },
  {
    label: 'Activity',
    title: '활동 분위기를 보고 싶다면',
    description: '행사 현장, 동아리 활동, 참가자 후기를 통해 실제 커뮤니티의 모습을 살펴봅니다.',
    href: '/blog/category/journal/',
    iconClass: 'is-violet',
    iconPath: 'M7.5 7.5h9m-9 4.5h5.25m-6.75 7.5h12A2.25 2.25 0 0 0 20.25 17.25V8.25A2.25 2.25 0 0 0 18 6H6A2.25 2.25 0 0 0 3.75 8.25v9A2.25 2.25 0 0 0 6 19.5Zm9.75-13.5V4.875A1.125 1.125 0 0 0 14.625 3.75h-5.25A1.125 1.125 0 0 0 8.25 4.875V6',
    links: [
      { label: '일지', href: '/blog/category/journal/' },
      { label: '동아리', href: '/blog/category/club/' },
      { label: '후기', href: '/blog/category/review/' },
    ],
  },
  {
    label: 'Deep Dive',
    title: '깊게 읽고 싶을 때',
    description: '운영 개발, 세미나, 연재 콘텐츠처럼 시간이 지나도 참고할 수 있는 글을 모았습니다.',
    href: '/blog/category/series/',
    iconClass: 'is-blue',
    iconPath: 'm9.75 9-3 3 3 3m4.5-6 3 3-3 3M14.25 4.5 9.75 19.5',
    links: [
      { label: '연재', href: '/blog/category/series/' },
      { label: '기술', href: '/blog/category/tech/' },
    ],
  },
] as const
---

<section class="section category-intro-band" id="reading-guide">
  <div class="shell category-intro-shell">
    <div class="section-head">
      <div>
        <p class="eyebrow">Reading Guide</p>
        <h2>목적에 맞게 읽기</h2>
        <p class="section-copy">
          최신 글을 훑기 전에, 지금 필요한 맥락에 맞춰 블로그 기록을 골라볼 수 있습니다.
        </p>
      </div>
    </div>

    <div class="category-intro-grid">
      {readingGuideCards.map((card) => (
        <article class="category-intro-card">
          <a class="category-intro-main" href={card.href}>
            <div class="category-intro-top">
              <div class={`category-intro-icon ${card.iconClass}`}>
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d={card.iconPath}></path>
                </svg>
              </div>
              <span class="category-intro-label">{card.label}</span>
              <h3>{card.title}</h3>
              <strong>{card.description}</strong>
            </div>
          </a>
          <div class="category-intro-links" aria-label={`${card.title} 세부 카테고리`}>
            {card.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
