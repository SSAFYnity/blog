---
import { categoryStyles, type CategorySlug, getCategoryTitle } from '../data/site'

interface Props {
  href: string
  slug?: string
  title: string
  description: string
  pubDate: Date
  category: CategorySlug
  coverImage?: string
  tags?: string[]
  metaLabel?: string
  hideCategory?: boolean
  variant?: 'default' | 'series'
}

const {
  href,
  slug,
  title,
  description,
  pubDate,
  category,
  coverImage,
  tags = [],
  metaLabel,
  hideCategory = false,
  variant = 'default',
} = Astro.props

const dateLabel = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate)

const analyticsPayload = JSON.stringify({
  post_slug: slug,
  post_title: title,
  post_category: category,
  destination_url: href,
  source_area: 'post_card',
})
---

<article class:list={['post-card', variant === 'series' && 'post-card-series']}>
  {coverImage && (
    <a
      class="post-card-cover"
      href={href}
      aria-label={`${title} 대표 이미지`}
      data-analytics-event="select_blog_post"
      data-analytics-payload={analyticsPayload}
    >
      <img src={coverImage} alt="" loading="lazy" />
    </a>
  )}

  {variant === 'series' ? (
    <>
      <a
        class="post-card-link"
        href={href}
        data-analytics-event="select_blog_post"
        data-analytics-payload={analyticsPayload}
      >
        <h3>{title}</h3>
      </a>

      <div class="series-card-foot">
        {tags.length > 0 && (
          <ul class="tag-list" aria-label="태그">
            {tags.map((tag) => (
              <li>#{tag}</li>
            ))}
          </ul>
        )}
        <time datetime={pubDate.toISOString()}>{dateLabel}</time>
      </div>
    </>
  ) : (
    <>
      <div class="post-meta-row">
        {metaLabel ? (
          <span class="post-series-card-meta">{metaLabel}</span>
        ) : !hideCategory && (
          <span class:list={['pill', categoryStyles[category] ?? 'is-slate']}>{getCategoryTitle(category)}</span>
        )}
        <time datetime={pubDate.toISOString()}>{dateLabel}</time>
      </div>

      <a
        class="post-card-link"
        href={href}
        data-analytics-event="select_blog_post"
        data-analytics-payload={analyticsPayload}
      >
        <h3>{title}</h3>
        {description && <p>{description}</p>}
      </a>

      {tags.length > 0 && (
        <ul class="tag-list" aria-label="태그">
          {tags.map((tag) => (
            <li>#{tag}</li>
          ))}
        </ul>
      )}
    </>
  )}
</article>
