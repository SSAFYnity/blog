---
import { site } from '../data/site'

const footerSocialLinks = site.socialLinks.filter((link) => link.showInFooter)

const socialIcons: Record<string, string> = {
  '문의하기': 'M5.25 8.25 12 12.75l6.75-4.5M6.75 6.75h10.5a1.5 1.5 0 0 1 1.5 1.5v7.5a1.5 1.5 0 0 1-1.5 1.5H6.75a1.5 1.5 0 0 1-1.5-1.5v-7.5a1.5 1.5 0 0 1 1.5-1.5Z',
  Instagram: 'M8.25 4.5h7.5A3.75 3.75 0 0 1 19.5 8.25v7.5a3.75 3.75 0 0 1-3.75 3.75h-7.5A3.75 3.75 0 0 1 4.5 15.75v-7.5A3.75 3.75 0 0 1 8.25 4.5Zm7.125 3.375h.008v.008h-.008v-.008ZM12 8.25A3.75 3.75 0 1 0 12 15.75 3.75 3.75 0 0 0 12 8.25Z',
  LinkedIn: 'M7.125 8.25a1.125 1.125 0 1 1 0-2.25 1.125 1.125 0 0 1 0 2.25ZM6 9.75h2.25v8.25H6V9.75Zm5.25 0h2.16v1.125h.03c.3-.57 1.035-1.17 2.13-1.17 2.28 0 2.7 1.5 2.7 3.45V18H16.02v-4.02c0-.96-.015-2.205-1.35-2.205-1.35 0-1.56 1.05-1.56 2.13V18H10.86V9.75h.39Z',
}
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div class="footer-block">
      <a class="footer-brand" href="/blog/" aria-label={`${site.shortName} 블로그 홈`}>
        <img src="/blog/logo.svg" alt="SSAFYnity" />
      </a>
      <p>{site.slogan}</p>
      <div class="footer-socials">
        {footerSocialLinks.map((link) => (
          <a class="footer-social-link" href={link.href} aria-label={link.label}>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d={socialIcons[link.label] ?? socialIcons['문의하기']}></path>
            </svg>
          </a>
        ))}
      </div>
    </div>

    <div class="footer-block">
      <div class="footer-nav-groups">
        <div>
          <p class="footer-eyebrow">블로그</p>
          <div class="footer-links">
            <a href="/blog/posts/">전체 글 보기</a>
            <a href="/blog/category/notice/">공지</a>
            <a href="/blog/category/journal/">일지</a>
            <a href="/blog/category/tech/">기술</a>
            <a href="/blog/category/review/">후기</a>
            <a href="/blog/category/finance/">회비</a>
          </div>
        </div>

        <div>
          <p class="footer-eyebrow">연결</p>
          <div class="footer-links">
            <a href={site.links.home}>공식 홈페이지</a>
            {footerSocialLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="shell footer-meta">
    <p>© {new Date().getFullYear()} SSAFYnity. All rights reserved.</p>
    <div class="footer-legal">
      <a href={site.links.privacy}>개인정보처리방침</a>
      <a href={site.links.terms}>이용약관</a>
    </div>
  </div>
</footer>
