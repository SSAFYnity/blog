---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import HomeCategoryIntro from '../components/HomeCategoryIntro.astro'
import HomeHero from '../components/HomeHero.astro'
import HomeLatestSection from '../components/HomeLatestSection.astro'
import HomeReviewInvite from '../components/HomeReviewInvite.astro'
import HomeArchiveSummary from '../components/HomeArchiveSummary.astro'
import { site } from '../data/site'
import { isPublicPost } from '../lib/content'

const posts = (await getCollection('posts'))
  .filter(isPublicPost)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

const leadPosts = posts.filter((post) => post.data.category !== 'review').slice(0, 6)
---

<BaseLayout title={`${site.title} | 공식 콘텐츠 아카이브`} description={site.description}>
  <HomeHero postsCount={posts.length} categoriesCount={site.categories.length} />
  <HomeCategoryIntro categories={site.categories} />
  <HomeLatestSection posts={leadPosts} />
  <HomeReviewInvite />
  <HomeArchiveSummary />
</BaseLayout>
