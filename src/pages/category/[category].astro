---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostCard from '../../components/PostCard.astro'
import { archiveEmptyMessages, archiveFilterLabels, archiveYearOptions, reviewAudienceLabels } from '../../data/archive'
import { categoryMap, categoryStyles, getCategoryTitle, site } from '../../data/site'
import { eventArchiveMap, eventKindLabels, getEventArchiveUrl } from '../../data/eventArchive'
import { buildArchiveSearchText, formatArchiveDate, formatReviewAuthor, getPostEventSlug, getReviewAuthorDisplayName } from '../../lib/archive'
import { isPublicPost } from '../../lib/content'

export async function getStaticPaths() {
  return site.categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }))
}

const { category } = Astro.props

const posts = (await getCollection('posts'))
  .filter((post) => isPublicPost(post) && post.data.category === category.slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

const categoryInfo = categoryMap[category.slug]

const renderedPosts = await Promise.all(
  posts.map(async (post) => ({
    post,
    ...(await render(post)),
  }))
)

const now = new Date()
const newPostThresholdMs = 7 * 24 * 60 * 60 * 1000
const isNewPost = (pubDate: Date) => {
  const ageMs = now.getTime() - pubDate.getTime()
  return ageMs >= 0 && ageMs <= newPostThresholdMs
}

const reviewKindOptions =
  category.slug === 'review'
    ? (Object.keys(eventKindLabels) as Array<keyof typeof eventKindLabels>)
    : []

const reviewColumns =
  category.slug === 'review'
    ? Array.from({ length: 3 }, (_, columnIndex) =>
        renderedPosts.filter((_, index) => index % 3 === columnIndex)
      )
    : []

---

<BaseLayout
  title={`${categoryInfo.title} | SSAFYnity 블로그`}
  description={categoryInfo.description}
>
  <section class="archive-hero-band archive-hero-band-category">
    <div class="archive-hero archive-hero-category shell">
      <p class="eyebrow">Category</p>
      <h1>{categoryInfo.title}</h1>
      <p class="archive-copy">{categoryInfo.description}</p>
    </div>
  </section>

  <section class="section section-muted archive-section-band">
    <div class="shell archive-section">
    {posts.length > 0 && <div class="archive-controls">
      {category.slug === 'review' && (
        <div class="archive-dropdown" data-dropdown>
          <button type="button" class="archive-pill-button" data-dropdown-trigger data-filter-kind-trigger>
            {archiveFilterLabels.reviewKind}
          </button>
          <div class="archive-dropdown-menu" data-dropdown-menu hidden>
            <button type="button" class="archive-dropdown-option is-selected" data-filter-kind-option data-value="">
              {archiveFilterLabels.allKinds}
            </button>
            {reviewKindOptions.map((kind) => (
              <button type="button" class="archive-dropdown-option" data-filter-kind-option data-value={kind}>
                {eventKindLabels[kind]}
              </button>
            ))}
          </div>
        </div>
      )}

      {category.slug === 'review' && (
        <div class="archive-dropdown" data-dropdown>
          <button type="button" class="archive-pill-button" data-dropdown-trigger data-filter-audience-trigger>
            {archiveFilterLabels.audience}
          </button>
          <div class="archive-dropdown-menu" data-dropdown-menu hidden>
            <button type="button" class="archive-dropdown-option is-selected" data-filter-audience-option data-value="">
              {archiveFilterLabels.allAudiences}
            </button>
            <button type="button" class="archive-dropdown-option" data-filter-audience-option data-value="member">
              {archiveFilterLabels.memberAudience}
            </button>
            <button type="button" class="archive-dropdown-option" data-filter-audience-option data-value="guest">
              {archiveFilterLabels.guestAudience}
            </button>
          </div>
        </div>
      )}

      <div class="archive-dropdown" data-dropdown>
        <button type="button" class="archive-pill-button" data-dropdown-trigger data-filter-year-trigger>
          {archiveFilterLabels.year}
        </button>
        <div class="archive-dropdown-menu" data-dropdown-menu hidden>
          <button type="button" class="archive-dropdown-option is-selected" data-filter-year-option data-value="">
            {archiveFilterLabels.allYears}
          </button>
          {archiveYearOptions.map((year) => (
            <button type="button" class="archive-dropdown-option" data-filter-year-option data-value={year.value}>
              {year.label}
            </button>
          ))}
        </div>
      </div>

      <div class="archive-search">
        <input
          type="search"
          placeholder={`${categoryInfo.title} 안에서 찾기`}
          data-filter-search
          aria-label={`${categoryInfo.title} 검색`}
        />
        <button type="button" class="archive-search-button" data-filter-submit>
          {archiveFilterLabels.searchButton}
        </button>
      </div>

      <div class="archive-dropdown" data-dropdown>
        <button type="button" class="archive-pill-button" data-dropdown-trigger data-filter-sort-trigger>
          {archiveFilterLabels.newest}
        </button>
        <div class="archive-dropdown-menu" data-dropdown-menu hidden>
          <button type="button" class="archive-dropdown-option is-selected" data-filter-sort-option data-value="newest">
            {archiveFilterLabels.newest}
          </button>
          <button type="button" class="archive-dropdown-option" data-filter-sort-option data-value="oldest">
            {archiveFilterLabels.oldest}
          </button>
        </div>
      </div>

      <button type="button" class="archive-reset" data-filter-reset hidden>
        {archiveFilterLabels.reset}
      </button>
    </div>}

    {posts.length === 0 && (
      <div class="archive-empty-state">
        <strong>{categoryInfo.title} 카테고리는 아직 비어 있습니다.</strong>
        <p>{archiveEmptyMessages[category.slug]}</p>
      </div>
    )}

    {posts.length > 0 && category.slug === 'notice' && (
      <div class="notice-list" data-filter-list>
        {posts.map((post) => (
          <a
            class="notice-row"
            href={`/blog/${post.slug}/`}
            data-analytics-event="select_blog_post"
            data-analytics-payload={JSON.stringify({
              post_slug: post.slug,
              post_title: post.data.title,
              post_category: post.data.category,
              destination_url: `/blog/${post.slug}/`,
              source_area: 'category_notice',
            })}
            data-filter-item
            data-date={post.data.pubDate.toISOString()}
            data-year={String(post.data.pubDate.getFullYear())}
            data-event={getPostEventSlug(post) ?? ''}
            data-tags={post.data.tags.join('|')}
            data-search={buildArchiveSearchText(post)}
          >
            <div class="notice-row-body">
              <div class="notice-row-head">
                <h2>
                  {post.data.title}
                  {isNewPost(post.data.pubDate) && <span class="notice-new-badge">NEW</span>}
                </h2>
                <time datetime={post.data.pubDate.toISOString()}>{formatArchiveDate(post.data.pubDate)}</time>
              </div>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    )}

    {posts.length > 0 && category.slug === 'journal' && (
      <div class="activity-log" data-filter-list>
        {posts.map((post) => (
          <a
            class="activity-card activity-card-journal"
            href={`/blog/${post.slug}/`}
            data-analytics-event="select_blog_post"
            data-analytics-payload={JSON.stringify({
              post_slug: post.slug,
              post_title: post.data.title,
              post_category: post.data.category,
              destination_url: `/blog/${post.slug}/`,
              source_area: 'category_journal',
            })}
            data-filter-item
            data-date={post.data.pubDate.toISOString()}
            data-year={String(post.data.pubDate.getFullYear())}
            data-event={getPostEventSlug(post) ?? ''}
            data-tags={post.data.tags.join('|')}
            data-search={buildArchiveSearchText(post)}
          >
            <div class="activity-card-head">
              <h2>{post.data.title}</h2>
              <time datetime={post.data.pubDate.toISOString()}>{formatArchiveDate(post.data.pubDate)}</time>
            </div>
            {post.data.tags.length > 0 && (
              <ul class="activity-tag-list" aria-label="태그">
                {post.data.tags.map((tag) => (
                  <li>#{tag}</li>
                ))}
              </ul>
            )}
          </a>
        ))}
      </div>
    )}

    {posts.length > 0 && (category.slug === 'series' || category.slug === 'tech') && (
      <div class:list={['post-grid', category.slug === 'series' && 'is-series']} data-filter-list>
        {posts.map((post) => (
          <div
            data-filter-item
            data-date={post.data.pubDate.toISOString()}
            data-year={String(post.data.pubDate.getFullYear())}
            data-event={getPostEventSlug(post) ?? ''}
            data-tags={post.data.tags.join('|')}
            data-search={buildArchiveSearchText(post)}
          >
            <PostCard
              href={`/blog/${post.slug}/`}
              slug={post.slug}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              coverImage={post.data.coverImage}
              tags={post.data.tags}
              hideCategory={post.data.category === 'series'}
              variant={post.data.category === 'series' ? 'series' : 'default'}
            />
          </div>
        ))}
      </div>
    )}

    {posts.length > 0 && category.slug === 'review' && (
      <div class="review-feed" data-filter-list data-review-layout="columns">
        {reviewColumns.map((column, columnIndex) => (
          <div class="review-column" data-review-column data-column-index={columnIndex}>
            {column.map(({ post, Content }) => {
              const eventSlug = getPostEventSlug(post)

              return (
                <div
                  class="review-entry-shell"
                  data-review-shell
                  data-filter-item
                  data-date={post.data.pubDate.toISOString()}
                  data-year={String(post.data.pubDate.getFullYear())}
                  data-event={eventSlug ?? ''}
                  data-kind={eventSlug ? eventArchiveMap[eventSlug]?.kind ?? '' : ''}
                  data-audience={post.data.review?.authorType ?? ''}
                  data-tags={post.data.tags.join('|')}
                  data-search={buildArchiveSearchText(post)}
                >
                  <article
                    id={post.slug}
                    class="review-entry"
                    data-review-entry
                  >
                    <div class="review-entry-meta">
                      {eventSlug && (
                        <a
                          class="review-event-link"
                          href={getEventArchiveUrl(eventSlug)}
                          target="_blank"
                          rel="noreferrer"
                        >
                          {eventArchiveMap[eventSlug].title}
                        </a>
                      )}

                      {post.data.review?.authorType && (
                        <span
                          class:list={[
                            'review-audience-badge',
                            post.data.review.authorType === 'member'
                              ? 'is-member'
                              : 'is-guest',
                          ]}
                        >
                          {reviewAudienceLabels[post.data.review.authorType]}
                        </span>
                      )}

                      {formatReviewAuthor(post.data.review) && (
                        <span class="review-author">{formatReviewAuthor(post.data.review)}</span>
                      )}
                    </div>

                    <div class="review-body" data-review-body>
                      <div class="prose review-prose review-prose-only" data-review-body-inner>
                        <Content />
                      </div>
                    </div>

                    <div class="review-entry-foot">
                      <time class="review-date" datetime={post.data.pubDate.toISOString()}>
                        {formatArchiveDate(post.data.pubDate)}
                      </time>

                      <div class="review-actions">
                        <button class="review-toggle" type="button" data-review-toggle hidden>
                          더보기
                        </button>

                        {post.data.review?.link && (
                          <a
                            class="review-anchor"
                            href={post.data.review.link}
                            target="_blank"
                            rel="noreferrer"
                            aria-label={`${getReviewAuthorDisplayName(post.data.review) ?? post.data.review.name} 링크 열기`}
                            title={`${getReviewAuthorDisplayName(post.data.review) ?? post.data.review.name} 링크 열기`}
                          >
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path
                                d="M7 17 17 7M9 7h8v8"
                                fill="none"
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.8"
                              />
                            </svg>
                          </a>
                        )}
                      </div>
                    </div>
                  </article>
                </div>
              )
            })}
          </div>
        ))}
      </div>
    )}

    {posts.length > 0 && category.slug === 'finance' && (
      <div class="finance-list" data-filter-list>
        {posts.map((post) => (
          <article
            class="finance-card"
            data-filter-item
            data-date={post.data.pubDate.toISOString()}
            data-year={String(post.data.pubDate.getFullYear())}
            data-event={getPostEventSlug(post) ?? ''}
            data-tags={post.data.tags.join('|')}
            data-search={buildArchiveSearchText(post)}
          >
            <div class="finance-card-top">
              <span class={`pill ${categoryStyles[post.data.category]}`}>{getCategoryTitle(post.data.category)}</span>
              <time datetime={post.data.pubDate.toISOString()}>{formatArchiveDate(post.data.pubDate)}</time>
            </div>
            <a
              href={`/blog/${post.slug}/`}
              data-analytics-event="select_blog_post"
              data-analytics-payload={JSON.stringify({
                post_slug: post.slug,
                post_title: post.data.title,
                post_category: post.data.category,
                destination_url: `/blog/${post.slug}/`,
                source_area: 'category_finance',
              })}
            >
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    )}

    {posts.length > 0 && (
      <div class="archive-empty-state is-filter-empty" data-filter-empty hidden>
        <strong>{archiveFilterLabels.filteredEmptyTitle}</strong>
        <p>{archiveFilterLabels.filteredEmptyDescription}</p>
      </div>
    )}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const filterList = document.querySelector('[data-filter-list]')
  const searchInput = document.querySelector('[data-filter-search]')
  const searchSubmit = document.querySelector('[data-filter-submit]')
  const kindTrigger = document.querySelector('[data-filter-kind-trigger]')
  const audienceTrigger = document.querySelector('[data-filter-audience-trigger]')
  const yearTrigger = document.querySelector('[data-filter-year-trigger]')
  const sortTrigger = document.querySelector('[data-filter-sort-trigger]')
  const kindOptions = [...document.querySelectorAll('[data-filter-kind-option]')]
  const audienceOptions = [...document.querySelectorAll('[data-filter-audience-option]')]
  const yearOptions = [...document.querySelectorAll('[data-filter-year-option]')]
  const sortOptions = [...document.querySelectorAll('[data-filter-sort-option]')]
  const resetButton = document.querySelector('[data-filter-reset]')
  const emptyState = document.querySelector('[data-filter-empty]')

  if (
    filterList instanceof HTMLElement &&
    searchInput instanceof HTMLInputElement &&
    searchSubmit instanceof HTMLButtonElement &&
    (!kindTrigger || kindTrigger instanceof HTMLButtonElement) &&
    (!audienceTrigger || audienceTrigger instanceof HTMLButtonElement) &&
    yearTrigger instanceof HTMLButtonElement &&
    sortTrigger instanceof HTMLButtonElement &&
    resetButton instanceof HTMLButtonElement
  ) {
    const items = [...filterList.querySelectorAll('[data-filter-item]')]
    const reviewColumns = [...filterList.querySelectorAll('[data-review-column]')]
    const params = new URLSearchParams(window.location.search)
    const initialEvent = params.get('event')?.trim() ?? ''
    let activeQuery = ''
    let activeKind = ''
    let activeAudience = ''
    let activeEvent = initialEvent
    let activeYear = ''
    let activeSort = 'newest'

    const getReviewColumnCount = () => {
      if (!reviewColumns.length) return 0
      if (window.matchMedia('(max-width: 900px)').matches) return 1
      if (window.matchMedia('(max-width: 1100px)').matches) return 2
      return 3
    }

    const redistributeReviewItems = (sortedItems) => {
      if (!reviewColumns.length) return

      const activeColumnCount = getReviewColumnCount()
      reviewColumns.forEach((column, index) => {
        if (!(column instanceof HTMLElement)) return
        column.hidden = index >= activeColumnCount
      })

      const activeColumns = reviewColumns
        .slice(0, activeColumnCount)
        .filter((column) => column instanceof HTMLElement)

      if (!activeColumns.length) return

      const visibleItems = sortedItems.filter((item) => !item.hasAttribute('hidden'))
      const hiddenItems = sortedItems.filter((item) => item.hasAttribute('hidden'))

      visibleItems.forEach((item, index) => {
        activeColumns[index % activeColumns.length].appendChild(item)
      })

      hiddenItems.forEach((item) => {
        activeColumns[0].appendChild(item)
      })
    }

    const applyFilters = () => {
      const sorted = [...items].sort((a, b) => {
        const aDate = Date.parse(a.getAttribute('data-date') ?? '')
        const bDate = Date.parse(b.getAttribute('data-date') ?? '')
        return activeSort === 'oldest' ? aDate - bDate : bDate - aDate
      })

      sorted.forEach((item) => {
        const haystack = (item.getAttribute('data-search') ?? '').toLowerCase()
        const kindValue = item.getAttribute('data-kind') ?? ''
        const audienceValue = item.getAttribute('data-audience') ?? ''
        const eventValue = item.getAttribute('data-event') ?? ''
        const yearValue = item.getAttribute('data-year') ?? ''
        const matchesQuery = !activeQuery || haystack.includes(activeQuery)
        const matchesKind = !activeKind || kindValue === activeKind
        const matchesAudience = !activeAudience || audienceValue === activeAudience
        const matchesEvent = !activeEvent || eventValue === activeEvent
        const matchesYear = !activeYear || yearValue === activeYear
        const visible = matchesQuery && matchesKind && matchesAudience && matchesEvent && matchesYear
        item.toggleAttribute('hidden', !visible)
      })

      redistributeReviewItems(sorted)

      if (emptyState instanceof HTMLElement) {
        const visibleCount = items.filter((item) => !item.hasAttribute('hidden')).length
        emptyState.hidden = visibleCount > 0
      }

      resetButton.hidden = !(activeQuery || activeKind || activeAudience || activeEvent || activeYear || activeSort !== 'newest')
    }

    const closeDropdowns = () => {
      document.querySelectorAll('[data-dropdown-menu]').forEach((menu) => {
        if (menu instanceof HTMLElement) menu.hidden = true
      })
    }

    document.querySelectorAll('[data-dropdown]').forEach((dropdown) => {
      const trigger = dropdown.querySelector('[data-dropdown-trigger]')
      const menu = dropdown.querySelector('[data-dropdown-menu]')
      if (!(trigger instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return

      trigger.addEventListener('click', () => {
        const nextHidden = !menu.hidden
        closeDropdowns()
        menu.hidden = nextHidden
      })
    })

    document.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Element) || !target.closest('[data-dropdown]')) {
        closeDropdowns()
      }
    })

    const submitSearch = () => {
      activeQuery = searchInput.value.trim().toLowerCase()
      applyFilters()
    }

    searchSubmit.addEventListener('click', submitSearch)
    searchInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') submitSearch()
    })

    sortOptions.forEach((option) => {
      if (!(option instanceof HTMLButtonElement)) return
      option.addEventListener('click', () => {
        activeSort = option.dataset.value ?? 'newest'
        sortTrigger.textContent = option.textContent?.trim() ?? '정렬'
        sortOptions.forEach((candidate) => candidate.classList.toggle('is-selected', candidate === option))
        closeDropdowns()
        applyFilters()
      })
    })

    kindOptions.forEach((option) => {
      if (!(option instanceof HTMLButtonElement)) return
      option.addEventListener('click', () => {
        activeKind = option.dataset.value ?? ''
        if (kindTrigger instanceof HTMLButtonElement) {
          kindTrigger.textContent = activeKind ? option.textContent?.trim() ?? '종류' : '종류'
        }
        kindOptions.forEach((candidate) => candidate.classList.toggle('is-selected', candidate === option))
        closeDropdowns()
        applyFilters()
      })
    })

    audienceOptions.forEach((option) => {
      if (!(option instanceof HTMLButtonElement)) return
      option.addEventListener('click', () => {
        activeAudience = option.dataset.value ?? ''
        if (audienceTrigger instanceof HTMLButtonElement) {
          audienceTrigger.textContent = activeAudience ? option.textContent?.trim() ?? '작성자' : '작성자'
        }
        audienceOptions.forEach((candidate) => candidate.classList.toggle('is-selected', candidate === option))
        closeDropdowns()
        applyFilters()
      })
    })

    yearOptions.forEach((option) => {
      if (!(option instanceof HTMLButtonElement)) return
      option.addEventListener('click', () => {
        activeYear = option.dataset.value ?? ''
        yearTrigger.textContent = activeYear ? option.textContent?.trim() ?? '연도' : '연도'
        yearOptions.forEach((candidate) => candidate.classList.toggle('is-selected', candidate === option))
        closeDropdowns()
        applyFilters()
      })
    })

    resetButton.addEventListener('click', () => {
      activeQuery = ''
      activeKind = ''
      activeAudience = ''
      activeEvent = ''
      activeYear = ''
      activeSort = 'newest'
      searchInput.value = ''
      if (kindTrigger instanceof HTMLButtonElement) kindTrigger.textContent = '종류'
      if (audienceTrigger instanceof HTMLButtonElement) audienceTrigger.textContent = '작성자'
      yearTrigger.textContent = '연도'
      sortTrigger.textContent = '최신순'
      kindOptions.forEach((option) => option.classList.toggle('is-selected', (option.dataset.value ?? '') === ''))
      audienceOptions.forEach((option) => option.classList.toggle('is-selected', (option.dataset.value ?? '') === ''))
      yearOptions.forEach((option) => option.classList.toggle('is-selected', (option.dataset.value ?? '') === ''))
      sortOptions.forEach((option) => option.classList.toggle('is-selected', option.dataset.value === 'newest'))
      window.history.replaceState({}, '', window.location.pathname)
      applyFilters()
    })

    applyFilters()
    window.addEventListener('resize', applyFilters)
  }

  const reviewEntries = document.querySelectorAll('[data-review-entry]')

  reviewEntries.forEach((entry) => {
    const shell = entry.closest('[data-review-shell]')
    const body = entry.querySelector('[data-review-body]')
    const toggle = entry.querySelector('[data-review-toggle]')

    if (
      !(shell instanceof HTMLElement) ||
      !(body instanceof HTMLElement) ||
      !(toggle instanceof HTMLButtonElement)
    ) {
      return
    }

    const collapse = () => {
      entry.classList.remove('is-expanded')
      shell.style.height = ''
      toggle.textContent = '더보기'
      toggle.setAttribute('aria-expanded', 'false')
    }

    const sync = () => {
      const wasExpanded = entry.classList.contains('is-expanded')
      if (wasExpanded) {
        entry.classList.remove('is-expanded')
      }

      const collapsedHeight = entry.offsetHeight
      entry.dataset.collapsedHeight = String(collapsedHeight)

      const overflowAmount = body.scrollHeight - body.clientHeight
      const isOverflow = overflowAmount > 24
      entry.classList.toggle('is-collapsible', isOverflow)
      toggle.hidden = !isOverflow

      if (isOverflow && wasExpanded) {
        entry.classList.add('is-expanded')
        shell.style.height = `${collapsedHeight}px`
      } else if (!isOverflow) {
        shell.style.height = ''
      }

      const expanded = entry.classList.contains('is-expanded')
      toggle.textContent = expanded ? '접기' : '더보기'
      toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false')
    }

    toggle.addEventListener('click', () => {
      const shouldExpand = !entry.classList.contains('is-expanded')

      reviewEntries.forEach((candidate) => {
        if (!(candidate instanceof HTMLElement) || candidate === entry) return
        const candidateShell = candidate.closest('[data-review-shell]')
        const candidateToggle = candidate.querySelector('[data-review-toggle]')
        if (
          !(candidateShell instanceof HTMLElement) ||
          !(candidateToggle instanceof HTMLButtonElement)
        ) {
          return
        }

        candidate.classList.remove('is-expanded')
        candidateShell.style.height = ''
        candidateToggle.textContent = '더보기'
        candidateToggle.setAttribute('aria-expanded', 'false')
      })

      if (shouldExpand) {
        const collapsedHeight = Number(entry.dataset.collapsedHeight || entry.offsetHeight)
        shell.style.height = `${collapsedHeight}px`
        entry.classList.add('is-expanded')
      } else {
        collapse()
      }

      const expanded = entry.classList.contains('is-expanded')
      toggle.textContent = expanded ? '접기' : '더보기'
      toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false')
    })

    requestAnimationFrame(sync)
    setTimeout(sync, 120)
    window.addEventListener('resize', sync)

    if ('ResizeObserver' in window) {
      const resizeObserver = new ResizeObserver(sync)
      resizeObserver.observe(body)
    }
  })
</script>
